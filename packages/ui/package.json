{
  "name": "@lancebailey26/skyforge-ui",
  "version": "0.0.5",
  "description": "Skyforge shared React UI components",
  "repository": {
    "type": "git",
    "url": "https://github.com/lancebailey26/skyforge.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.module.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme/tokens.css": "./src/theme/tokens.css",
    "./theme/tokens.schema.json": "./src/theme/tokens.schema.json"
  },
  "files": [
    "dist",
    "src/theme/tokens.css",
    "src/theme/tokens.schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && copyfiles -u 1 \"src/**/*.css\" \"src/**/*.json\" dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint src",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.7",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "copyfiles": "^2.4.1",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.7",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "reactflow": "^11.11.4"
  }
}
