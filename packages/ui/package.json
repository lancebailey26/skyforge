{
    "name": "@lancebailey26/skyforge-ui",
    "version": "0.0.1",
    "description": "Skyforge shared React UI components",
    "repository": {
        "type": "git",
        "url": "https://github.com/lancebailey26/skyforge.git",
        "directory": "packages/ui"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "sideEffects": [
        "**/*.css",
        "**/*.module.css"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./theme/tokens.css": "./dist/theme/tokens.css",
        "./theme/tokens.schema.json": "./dist/theme/tokens.schema.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && copyfiles -u 1 \"src/**/*.css\" \"src/**/*.json\" dist",
        "prepublishOnly": "npm run build",
        "lint": "eslint src",
        "test": "echo \"no tests yet\""
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.2",
        "@types/react-dom": "^19.2.0",
        "copyfiles": "^2.4.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.1.0",
        "@fortawesome/free-brands-svg-icons": "^7.1.0",
        "@fortawesome/free-regular-svg-icons": "^7.1.0",
        "@fortawesome/free-solid-svg-icons": "^7.1.0",
        "@fortawesome/react-fontawesome": "^3.1.0",
        "reactflow": "^11.11.4"
    }
}
