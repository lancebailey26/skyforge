{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
      "dev": {
        "cache": false
      },
      "build": {
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          ".next/**",
          "dist/**"
        ]
      },
      "lint": {
        "outputs": []
      },
      "test": {
        "outputs": []
      },
      "test:e2e": {
        "cache": false,
        "outputs": []
      }
    }
  }
  