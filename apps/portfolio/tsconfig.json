{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "skipLibCheck": true,
        "baseUrl": ".",
      "plugins": [
        {
          "name": "next"
        }
      ],
      "paths": {
        "@/*": ["./src/*"]
      }
    },
    "include": [
      "next-env.d.ts",
      "**/*.ts",
      "**/*.tsx"
    ],
    "exclude": [
      "node_modules"
    ]
  }
  